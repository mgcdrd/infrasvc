---
apiVersion: apiserver.config.k8s.io/v1
kind: AdmissionConfiguration
plugins:
  - name: PodSecurity
    configuration:
      apiVersion: pod-security.admission.config.k8s.io/v1
      kind: PodSecurityConfiguration
      defaults:
        enforce: "{{ k8s_psa_enforce }}"
        enforce-version: "{{ k8s_psa_version }}"
        warn: "{{ k8s_psa_warn }}"
        warn-version: "{{ k8s_psa_version }}"
        audit: "{{ k8s_psa_audit }}"
        audit-version: "{{ k8s_psa_version }}"
      exemptions:
        usernames: []
        runtimeClasses: []
        namespaces:
{{ k8s_psa_exempt_namespaces | to_nice_yaml(indent=2) | indent(10, first=true) }}
