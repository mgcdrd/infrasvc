---
apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
bootstrapTokens:
- groups:
  - system:bootstrappers:kubeadm:default-node-token
  token: {{ k8s_init_token }}
  ttl: 4h0m0s
  usages:
  - signing
  - authentication
localAPIEndpoint:
  advertiseAddress: {{ lookup('community.general.dig', k8s_control_plane_endpoint) }}
  bindPort: 6443
nodeRegistration:
  criSocket: unix:///var/run/crio/crio.sock
  imagePullPolicy: IfNotPresent
  imagePullSerial: true
  name: {{ inventory_hostname }}
  taints: null
timeouts:
  controlPlaneComponentHealthCheck: 4m0s
  discovery: 5m0s
  etcdAPICall: 2m0s
  kubeletHealthCheck: 4m0s
  kubernetesAPICall: 1m0s
  tlsBootstrap: 5m0s
  upgradeManifests: 5m0s
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
{% if k8s_control_plane_endpoint is defined or k8s_psa_enabled or k8s_oidc_enabled %}
apiServer:
{% if k8s_control_plane_endpoint is defined %}
  certSANs:
    - {{ k8s_control_plane_endpoint }}
{% endif %}
{% if k8s_psa_enabled or k8s_oidc_enabled %}
  extraArgs:
{% if k8s_psa_enabled %}
    - name: admission-control-config-file
      value: /etc/kubernetes/psa-admission.yml
{% endif %}
{% if k8s_oidc_enabled %}
    - name: oidc-issuer-url
      value: "{{ k8s_oidc_issuer_url }}"
    - name: oidc-client-id
      value: "{{ k8s_oidc_client_id }}"
    - name: oidc-username-claim
      value: "{{ k8s_oidc_username_claim }}"
    - name: oidc-groups-claim
      value: "{{ k8s_oidc_groups_claim }}"
{% endif %}
{% endif %}
{% if k8s_psa_enabled %}
  extraVolumes:
    - name: psa-admission-config
      hostPath: /etc/kubernetes/psa-admission.yml
      mountPath: /etc/kubernetes/psa-admission.yml
      readOnly: true
      pathType: File
{% endif %}
{% else %}
apiServer: {}
{% endif %}
caCertificateValidityPeriod: 87600h0m0s
certificateValidityPeriod: 8760h0m0s
certificatesDir: /etc/kubernetes/pki
clusterName: kubernetes
controllerManager: {}
dns: {}
encryptionAlgorithm: RSA-2048
etcd:
  local:
    dataDir: /var/lib/etcd
imageRepository: registry.k8s.io
kubernetesVersion: {{ k8s_version }}.0
networking:
  dnsDomain: cluster.local
  serviceSubnet: {{ k8s_svc_cidr }}
  podSubnet: {{ k8s_pod_cidr }}
{% if k8s_control_plane_endpoint is defined %}
controlPlaneEndpoint: "{{ k8s_control_plane_endpoint }}:6443"
{% endif %}
proxy: {}
scheduler: {}
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: KubeProxyConfiguration
mode: "ipvs"
ipvs:
  strictARP: true