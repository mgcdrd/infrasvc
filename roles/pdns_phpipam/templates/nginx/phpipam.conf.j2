# Managed by Ansible — mgcdrd.infrasvc.pdns_phpipam
# nginx SSL frontend for phpipam-web
# phpipam-web must have IPAM_TRUST_X_FORWARDED=true set (handled by role).

server {
    listen      80;
    server_name {{ pdns_phpipam_ssl_hostname | default(inventory_hostname, true) }};
    return 301  https://$host$request_uri;
}

server {
    listen      443 ssl;
    server_name {{ pdns_phpipam_ssl_hostname | default(inventory_hostname, true) }};

    ssl_certificate     /etc/ssl/phpipam/fullchain.pem;
    ssl_certificate_key /etc/ssl/phpipam/key.pem;

    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    location / {
        proxy_pass         http://{{ pdns_phpipam_docker_network_ipam_web }};
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
