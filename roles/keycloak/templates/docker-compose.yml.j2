---
# Managed by Ansible — mgcdrd.infrasvc.keycloak
# Manual edits will be overwritten on next run.

services:

  keycloak:
    image: "{{ keycloak_image }}:{{ keycloak_version }}"
    container_name: keycloak
    restart: unless-stopped
    environment:
      KC_HOSTNAME:                   "{{ keycloak_hostname }}"
      KC_HOSTNAME_PORT:              "443"
      KC_HTTP_PORT:                  "{{ keycloak_http_port }}"
      KC_HTTPS_PORT:                 "{{ keycloak_https_port }}"
      KC_HTTPS_CERTIFICATE_FILE:     "/certs/fullchain.pem"
      KC_HTTPS_CERTIFICATE_KEY_FILE: "/certs/key.pem"
      KC_HEALTH_ENABLED:             "true"
      KC_DB:                         postgres
      KC_DB_URL_HOST:                "{{ postgres_host }}"
      KC_DB_URL_PORT:                "{{ postgres_port }}"
      KC_DB_USERNAME:                "{{ keycloak_db_user }}"
      KC_DB_PASSWORD:                "{{ keycloak_db_password }}"
      KC_BOOTSTRAP_ADMIN_USERNAME:   "{{ keycloak_admin_user }}"
      KC_BOOTSTRAP_ADMIN_PASSWORD:   "{{ keycloak_admin_password }}"
{% for key, value in keycloak_extra_env.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
    command: start
{% if keycloak_network_mode == 'host' %}
    network_mode: host
{% else %}
    ports:
      - "{{ keycloak_http_port }}:{{ keycloak_http_port }}"
      - "{{ keycloak_https_port }}:{{ keycloak_https_port }}"
      - "{{ keycloak_mgmt_port }}:{{ keycloak_mgmt_port }}"
      - "{{ keycloak_jgroups_port }}:{{ keycloak_jgroups_port }}"
      - "{{ keycloak_jgroups_fd_port }}:{{ keycloak_jgroups_fd_port }}"
    networks:
      - frontend
{% endif %}
    volumes:
      - type: bind
        source: "{{ keycloak_cert_dir }}"
        target: /certs
        read_only: true
        bind:
          selinux: z
      - type: bind
        source: "{{ _keycloak_data_dir }}/conf_truststores"
        target: /opt/keycloak/conf/truststores
        bind:
          selinux: z
      - type: bind
        source: "{{ _keycloak_data_dir }}/themes"
        target: /opt/keycloak/themes
        bind:
          selinux: z

{% if keycloak_network_mode == 'bridge' %}
networks:
  frontend:
    driver: bridge
{% endif %}
